{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for Lesson Material Scheduler",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file=.env.dev server.js",
    "dev": "node --env-file=.env.dev --watch server.js",
    "test": "cross-env NODE_ENV=test vitest",
    "test:watch": "cross-env NODE_ENV=test vitest --watch",
    "test:coverage": "cross-env NODE_ENV=test vitest --coverage",
    "prod": "node --env-file=.env.prod server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongodb": "^6.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "supertest": "^6.3.3",
    "@vitest/coverage-v8": "^1.0.0",
    "cross-env": "^7.0.3"
  }
}
